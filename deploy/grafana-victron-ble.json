{
  "__inputs": [
    {
      "name": "DS_INFLUXDB",
      "label": "InfluxDB",
      "description": "VE.Direct data source (Flux)",
      "type": "datasource",
      "pluginId": "influxdb",
      "pluginName": "InfluxDB"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "influxdb",
      "name": "InfluxDB",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "barchart",
      "name": "Bar chart",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "text",
      "name": "Text",
      "version": ""
    }
  ],
  "title": "Victron Solar — Bluetooth (Instant Readout)",
  "uid": null,
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "timezone": "browser",
  "tags": [
    "victron",
    "vedirect",
    "solar",
    "bluetooth"
  ],
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 99,
      "type": "text",
      "title": "",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 3
      },
      "options": {
        "mode": "markdown",
        "content": "**Source: Bluetooth — SmartSolar Instant Readout (no VE.Direct cable).** Live subset only; the **Daily history** panels below are *derived* from the logged live samples (not the charger's on-device history register). `pv_voltage`, lifetime `yield_total`, `tracker_mode` are not in the BLE advert — use the **VE.Direct (USB)** dashboard for the device-recorded history and those fields."
      }
    },
    {
      "id": 1,
      "type": "row",
      "title": "☀ Live",
      "gridPos": {
        "x": 0,
        "y": 3,
        "w": 24,
        "h": 1
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 10,
      "type": "stat",
      "title": "PV Power",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "influxdb",
        "uid": "${DS_INFLUXDB}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "color": {
            "mode": "fixed",
            "fixedColor": "yellow"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "refId": "A",
          "query": "from(bucket: v.defaultBucket) |> range(start: -5m) |> filter(fn:(r)=>r._measurement==\"victron_mppt\" and r._field==\"pv_power\") |> last()"
        }
      ],
      "description": "Solar power currently harvested by the MPPT. VE.Direct field `PPV`."
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Battery V",
      "gridPos": {
        "x": 4,
        "y": 4,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "influxdb",
        "uid": "${DS_INFLUXDB}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "volt",
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          },
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "refId": "A",
          "query": "from(bucket: v.defaultBucket) |> range(start: -5m) |> filter(fn:(r)=>r._measurement==\"victron_mppt\" and r._field==\"battery_voltage\") |> last()"
        }
      ],
      "description": "Battery terminal voltage measured by the MPPT. VE.Direct field `V`."
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Battery A",
      "gridPos": {
        "x": 8,
        "y": 4,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "influxdb",
        "uid": "${DS_INFLUXDB}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "amp",
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          },
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "refId": "A",
          "query": "from(bucket: v.defaultBucket) |> range(start: -5m) |> filter(fn:(r)=>r._measurement==\"victron_mppt\" and r._field==\"battery_current\") |> last()"
        }
      ],
      "description": "Charge current into the battery. Positive = charging from solar, ~0 = idle/float, negative = net draw. VE.Direct field `I`."
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Yield Today",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "influxdb",
        "uid": "${DS_INFLUXDB}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "kwatth",
          "color": {
            "mode": "fixed",
            "fixedColor": "orange"
          },
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "refId": "A",
          "query": "from(bucket: v.defaultBucket) |> range(start: -5m) |> filter(fn:(r)=>r._measurement==\"victron_mppt\" and r._field==\"yield_today_kwh\") |> last()"
        }
      ],
      "description": "Energy harvested today. VE.Direct field `H20` (×0.01 kWh)."
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Charge State",
      "gridPos": {
        "x": 16,
        "y": 4,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "influxdb",
        "uid": "${DS_INFLUXDB}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "purple"
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "Off"
                },
                "3": {
                  "text": "Bulk"
                },
                "4": {
                  "text": "Absorption"
                },
                "5": {
                  "text": "Float"
                }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "refId": "A",
          "query": "from(bucket: v.defaultBucket) |> range(start: -5m) |> filter(fn:(r)=>r._measurement==\"victron_mppt\" and r._field==\"charge_state\") |> last()"
        }
      ],
      "description": "MPPT charge stage code: 0=Off, 3=Bulk, 4=Absorption, 5=Float. VE.Direct field `CS`."
    },
    {
      "id": 15,
      "type": "stat",
      "title": "Error",
      "gridPos": {
        "x": 20,
        "y": 4,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "influxdb",
        "uid": "${DS_INFLUXDB}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds",
            "fixedColor": "blue"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "OK"
                }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "refId": "A",
          "query": "from(bucket: v.defaultBucket) |> range(start: -5m) |> filter(fn:(r)=>r._measurement==\"victron_mppt\" and r._field==\"error_code\") |> last()"
        }
      ],
      "description": "MPPT error code, 0 = no error. VE.Direct field `ERR`."
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Solar PV Power",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "influxdb",
        "uid": "${DS_INFLUXDB}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20
          },
          "color": {
            "mode": "fixed",
            "fixedColor": "yellow"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "refId": "A",
          "query": "from(bucket: v.defaultBucket) |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn:(r)=>r._measurement==\"victron_mppt\" and r._field==\"pv_power\") |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)"
        }
      ],
      "description": "Solar power currently harvested by the MPPT. VE.Direct field `PPV`."
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Battery Voltage & Current",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "influxdb",
        "uid": "${DS_INFLUXDB}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "volt",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "refId": "A",
          "query": "from(bucket: v.defaultBucket) |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn:(r)=>r._measurement==\"victron_mppt\" and r._field==\"battery_voltage\") |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)"
        },
        {
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "refId": "B",
          "query": "from(bucket: v.defaultBucket) |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn:(r)=>r._measurement==\"victron_mppt\" and r._field==\"battery_current\") |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)"
        }
      ],
      "description": "Battery terminal voltage (VE.Direct `V`) and charge current (VE.Direct `I`) over time. Positive current = charging from solar."
    },
    {
      "id": 2,
      "type": "row",
      "title": "📅 Daily history",
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 24,
        "h": 1
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 30,
      "type": "barchart",
      "title": "Daily Solar Yield (kWh)",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 16,
        "h": 8
      },
      "datasource": {
        "type": "influxdb",
        "uid": "${DS_INFLUXDB}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "kwatth",
          "color": {
            "mode": "fixed",
            "fixedColor": "yellow"
          },
          "custom": {
            "fillOpacity": 80,
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "vertical",
        "showValue": "auto",
        "xTickLabelRotation": -45,
        "legend": {
          "showLegend": false
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "refId": "A",
          "query": "import \"timezone\"\noption location = timezone.location(\"Europe/Berlin\")\nfrom(bucket: v.defaultBucket)\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn:(r)=>r._measurement==\"victron_mppt\" and r._field==\"yield_today_kwh\")\n  |> aggregateWindow(every: 1d, fn: max, createEmpty: false, timeSrc: \"_start\")\n  |> keep(columns:[\"_time\",\"_value\"])"
        }
      ],
      "description": "Daily yield derived from the live `yield_today_kwh` (cumulative, resets at local midnight): the day's max = that day's total. Derived over BLE — no on-device history register."
    },
    {
      "id": 31,
      "type": "barchart",
      "title": "Max PV Power / day (W)",
      "gridPos": {
        "x": 16,
        "y": 16,
        "w": 8,
        "h": 8
      },
      "datasource": {
        "type": "influxdb",
        "uid": "${DS_INFLUXDB}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "color": {
            "mode": "fixed",
            "fixedColor": "orange"
          },
          "custom": {
            "fillOpacity": 80,
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "vertical",
        "showValue": "auto",
        "xTickLabelRotation": -45,
        "legend": {
          "showLegend": false
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "refId": "A",
          "query": "import \"timezone\"\noption location = timezone.location(\"Europe/Berlin\")\nfrom(bucket: v.defaultBucket)\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn:(r)=>r._measurement==\"victron_mppt\" and r._field==\"pv_power\")\n  |> aggregateWindow(every: 1d, fn: max, createEmpty: false, timeSrc: \"_start\")\n  |> keep(columns:[\"_time\",\"_value\"])"
        }
      ],
      "description": "Peak PV power that day, derived from live `pv_power` samples (BLE)."
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "Daily Battery V (min/max)",
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 24,
        "h": 7
      },
      "datasource": {
        "type": "influxdb",
        "uid": "${DS_INFLUXDB}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "volt",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "refId": "A",
          "query": "import \"timezone\"\noption location = timezone.location(\"Europe/Berlin\")\nfrom(bucket: v.defaultBucket)\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn:(r)=>r._measurement==\"victron_mppt\" and r._field==\"battery_voltage\")\n  |> aggregateWindow(every: 1d, fn: max, createEmpty: false, timeSrc: \"_start\")\n  |> keep(columns:[\"_time\",\"_value\"])"
        },
        {
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "refId": "B",
          "query": "import \"timezone\"\noption location = timezone.location(\"Europe/Berlin\")\nfrom(bucket: v.defaultBucket)\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn:(r)=>r._measurement==\"victron_mppt\" and r._field==\"battery_voltage\")\n  |> aggregateWindow(every: 1d, fn: min, createEmpty: false, timeSrc: \"_start\")\n  |> keep(columns:[\"_time\",\"_value\"])"
        }
      ],
      "description": "Daily highest/lowest battery voltage, derived from live `battery_voltage` samples (BLE)."
    }
  ]
}
